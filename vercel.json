{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install --include=optional && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/ingresos/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
